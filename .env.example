# Copy to .env and set values. Do not commit .env.

# Database (PostgreSQL). For local dev, run Postgres (e.g. Docker):
#   docker run -d -p 5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=daypilot postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daypilot"

# API (for apps/api). Use 3001 when running next to Next.js (web on 3000).
PORT=3001
JWT_SECRET="your-super-secret-key-min-32-chars"

# CORS: comma-separated (web + Flutter dev). Add production origins when deploying.
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Billing (Stripe). Optional — omit to disable checkout; webhook and portal require these.
FRONTEND_URL="http://localhost:3000"
# When web runs on another port (e.g. 3002): FRONTEND_URL="http://localhost:3002"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PERSONAL="price_..."
# STRIPE_PRICE_BUSINESS="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."

# AI — one of: openai (default), openai-compatible, anthropic. Omit keys to disable.
# AI_PROVIDER=openai
# OpenAI (or OpenAI-compatible: Together, Groq, OpenRouter, Ollama, etc.)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
# For OpenAI-compatible APIs (e.g. Together, Groq): set base URL and use AI_PROVIDER=openai-compatible
# OPENAI_BASE_URL="https://api.together.xyz/v1"
# Anthropic (Claude)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# --- Web (apps/web/.env.local) — Supabase Auth + data ---
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"
# NEXT_PUBLIC_API_URL="http://localhost:3001"  # Nest bridge during migration
# NEXT_PUBLIC_SITE_URL="https://daypilot.co"

# --- Option C (Flutter + Supabase auth + Nest events) — required for /auth/supabase-exchange ---
# Prefer JWT signing keys (ES256): same project URL as Flutter (Data API / Connect). No trailing slash.
# SUPABASE_URL="https://YOUR_REF.supabase.co"
# Legacy symmetric-only projects: HS256 JWT secret from Dashboard → JWT (not the anon key / not Key ID).
# SUPABASE_JWT_SECRET="your-legacy-jwt-secret"

# Connected calendars (OAuth). See docs/CALENDAR_INTEGRATIONS_SETUP.md
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3002"
# OAuth redirect URIs (register in Google Cloud / Azure):
#   {API_URL}/calendar-connections/google/callback
#   {API_URL}/calendar-connections/outlook/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Apple / iCloud: CalDAV setup coming later

# Observability (Phase 11). Optional — omit to disable.
# API: error tracking
# SENTRY_DSN="https://...@sentry.io/..."
# Web: error tracking (set in Vercel / host)
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# Source map upload (CI): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
