# Copy to .env and set values. Do not commit .env.

# Database (PostgreSQL). For local dev, run Postgres (e.g. Docker):
#   docker run -d -p 5432:5432 -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=daypilot postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daypilot"

# API (for apps/api). Use 3001 when running next to Next.js (web on 3000).
PORT=3001
JWT_SECRET="your-super-secret-key-min-32-chars"
CORS_ORIGIN="http://localhost:3000"

# Billing (Stripe). Optional — omit to disable checkout; webhook and portal require these.
# FRONTEND_URL="http://localhost:3000"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PERSONAL="price_..."
# STRIPE_PRICE_BUSINESS="price_..."
# STRIPE_PRICE_ENTERPRISE="price_..."

# AI — one of: openai (default), openai-compatible, anthropic. Omit keys to disable.
# AI_PROVIDER=openai
# OpenAI (or OpenAI-compatible: Together, Groq, OpenRouter, Ollama, etc.)
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"
# For OpenAI-compatible APIs (e.g. Together, Groq): set base URL and use AI_PROVIDER=openai-compatible
# OPENAI_BASE_URL="https://api.together.xyz/v1"
# Anthropic (Claude)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-haiku-20241022"

# Connected calendars (OAuth). Optional — omit to hide Connect buttons.
# API_URL="http://localhost:3001"   # Your API base URL (for OAuth redirect_uri)
# Google Calendar
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# Outlook / Microsoft 365
# MICROSOFT_CLIENT_ID="..."
# MICROSOFT_CLIENT_SECRET="..."
# Apple / iCloud: CalDAV setup coming later

# Observability (Phase 11). Optional — omit to disable.
# API: error tracking
# SENTRY_DSN="https://...@sentry.io/..."
# Web: error tracking (set in Vercel / host)
# NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
# Source map upload (CI): SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT
