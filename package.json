{
  "name": "daypilot",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered scheduling assistant",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @daypilot/api dev",
    "db:up": "docker compose up -d postgres",
    "flutter:run": "bash daypilot_flutter/run.sh",
    "flutter:run:web": "bash daypilot_flutter/run.sh -d chrome",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean --force && rm -rf node_modules",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}