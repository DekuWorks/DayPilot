# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: DayPilot API base URL (when moving off Supabase). If set, auth (login/signup/Google) and integrations (connect Google, discover) use this API.
# Example: https://daypilot-api.fly.dev
# VITE_API_URL=https://daypilot-api.fly.dev

# Optional: Custom API for Google Calendar discovery only (if not using VITE_API_URL).
# VITE_GOOGLE_DISCOVER_API_URL=https://your-api.com

# Email Configuration (Optional - for production)
VITE_EMAIL_API_URL=https://api.resend.com/emails
VITE_EMAIL_API_KEY=your_resend_api_key_here
VITE_EMAIL_FROM=noreply@daypilot.app
